{
  "name": "shrimp-check",
  "displayName": "Shrimp Check",
  "description": "A playful VS Code extension that reminds you to fix your posture before you become a full crustacean.",
  "version": "0.0.7",
  "publisher": "contractos",
  "license": "MIT",
  "icon": "images/shrimp-check-logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coollifeclc/shrimpcheck.git"
  },
  "homepage": "https://github.com/coollifeclc/shrimpcheck",
  "categories": [
    "Other"
  ],
  "keywords": [
    "posture",
    "health",
    "reminder",
    "productivity",
    "funny",
    "shrimp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shrimpCheck.openQuickMenu",
        "title": "Shrimp Check: Open Quick Menu"
      },
      {
        "command": "shrimpCheck.timerMenu",
        "title": "Shrimp Check: Timer Settings"
      },
      {
        "command": "shrimpCheck.openSettings",
        "title": "Shrimp Check: Open Settings"
      },
      {
        "command": "shrimpCheck.hydrationMenu",
        "title": "Shrimp Check: Hydration Menu"
      },
      {
        "command": "shrimpCheck.resetPosture",
        "title": "Shrimp Check: Reset Posture Timer"
      },
      {
        "command": "shrimpCheck.snooze",
        "title": "Shrimp Check: Snooze 10 Minutes"
      },
      {
        "command": "shrimpCheck.toggle",
        "title": "Shrimp Check: Enable/Disable"
      }
    ],
    "configuration": {
      "title": "Shrimp Check",
      "properties": {
        "shrimpCheck.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Shrimp Check reminders."
        },
        "shrimpCheck.minMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 30,
          "description": "Minimum number of minutes before a posture reminder."
        },
        "shrimpCheck.maxMinutes": {
          "type": "number",
          "default": 45,
          "minimum": 45,
          "description": "Maximum number of minutes before a posture reminder."
        },
        "shrimpCheck.warningFraction": {
          "type": "number",
          "default": 0.66,
          "minimum": 0.1,
          "maximum": 0.95,
          "description": "Fraction of the posture cycle after which the warning state begins."
        },
        "shrimpCheck.showPopup": {
          "type": "boolean",
          "default": true,
          "description": "Show popup reminders for posture events."
        },
        "shrimpCheck.cookedDelayMinutes": {
          "type": "number",
          "default": 10,
          "minimum": 10,
          "description": "Minutes after the warning state before you become cooked."
        },
        "shrimpCheck.hydrationEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable hydration reminders."
        },
        "shrimpCheck.hydrationMinutes": {
          "type": "number",
          "default": 45,
          "minimum": 45,
          "description": "Minutes between hydration reminders."
        },
        "shrimpCheck.drink": {
          "type": "string",
          "default": "",
          "description": "Your preferred coding beverage for hydration messages. Falls back to 'caffeine' if left blank."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}
